# ============================================================================
# ShopTalk Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values

# ============================================================================
# Clerk Authentication
# ============================================================================
# Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Mobile app (Expo public vars)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ============================================================================
# Supabase / Database
# ============================================================================
# Get these from https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ============================================================================
# Pinecone Vector Database
# ============================================================================
# Get these from https://app.pinecone.io
PINECONE_API_KEY=...
PINECONE_INDEX=teamster-contracts

# ============================================================================
# OpenAI (for embeddings)
# ============================================================================
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ============================================================================
# Anthropic (for LLM responses)
# ============================================================================
# Get this from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# PostHog Analytics
# ============================================================================
# Get this from https://app.posthog.com
POSTHOG_API_KEY=phc_...
EXPO_PUBLIC_POSTHOG_API_KEY=phc_...

# ============================================================================
# Sentry Error Tracking
# ============================================================================
# Get these from https://sentry.io
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...

# ============================================================================
# API URL (for mobile app)
# ============================================================================
# Local development
EXPO_PUBLIC_API_URL=http://localhost:8787

# Production (update after deploying API)
# EXPO_PUBLIC_API_URL=https://api.shoptalk.app
